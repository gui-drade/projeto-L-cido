<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Gerenciamento de Alunos</title>
</head>
<style>
    body { background: #0A0D11; color: #F0F2F5; font-family: sans-serif; padding: 40px; }
    .topo-busca { display: flex; gap: 20px; margin-bottom: 30px; align-items: center;}
    .busca-input { background: #1F2A38; border: 2px solid #CBD2DE; color: white; padding: 12px 20px; border-radius: 50px; flex-grow: 1; outline: none; font-size: 1rem; }
    .btn { padding: 12px 25px; border-radius: 50px; border: 2px solid #CBD2DE; cursor: pointer; font-weight: bold; }
    .btn-voltar { background: linear-gradient(180deg, #2b3b4f, #020203); color: white; }
    .card-aluno { background: #1F2A38; padding: 20px; border-radius: 16px; margin-bottom: 15px; box-shadow: 0px 5px 15px rgba(0,0,0,0.3); }
    .linha-edit { display: flex; gap: 15px; margin-top: 15px; }
    .input-edit { background: #0A0D11; border: 1px solid #CBD2DE; color: white; padding: 8px 12px; border-radius: 6px; outline: none; }
</style>
<body>
    <div class="topo-busca">
        <form action="/gerenciar-alunos" method="GET" style="display: flex; flex-grow: 1; gap: 10px;">
            <input type="text" name="pesquisa" class="busca-input" placeholder="Pesquisar Aluno..." value="{{pesquisa}}">
            <button type="submit" class="btn" style="background: #CBD2DE; color: #0A0D11;">Buscar</button>
        </form>
        <button class="btn btn-voltar" onclick="window.location.href='/acoes-rapidas'">Voltar</button>
    </div>

    <div class="lista-alunos">
        {{#each alunos}}
        <div class="card-aluno">
            <form action="/aluno/editar/{{this.id}}" method="POST">
                <div>
                    <strong>Nome:</strong> <input type="text" name="nome" class="input-edit" value="{{this.nome}}" required>
                    <strong>E-mail:</strong> <input type="email" name="email" class="input-edit" value="{{this.email}}" required>
                </div>
                <div class="linha-edit">
                    <button type="submit" class="btn" style="background: #238636; color: white; border: none; padding: 8px 20px;">Salvar Alteração</button>
                    <a href="/aluno/deletar/{{this.id}}" class="btn" style="background: #f85149; color: white; border: none; text-decoration: none; padding: 8px 20px; display: inline-block; font-size: 0.9rem;">Excluir Conta</a>
                </div>
            </form>
        </div>
        {{else}}
        <p style="text-align: center; color: #CBD2DE;">Nenhum aluno cadastrado ou encontrado.</p>
        {{/each}}
    </div>
</body>
</html>