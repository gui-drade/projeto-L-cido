<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Cadastro de Usuário</title>
</head>
<style>
    body { background: linear-gradient(135deg, #030406 0%, #223447 100%); color: #F0F2F5; display: flex; justify-content: center; align-items: center; height: 100vh; font-family: sans-serif; margin: 0; }
    .cadastro-container { background-color: #1F2A38; width: 100%; max-width: 500px; padding: 40px; border-radius: 16px; box-shadow: 0px 10px 30px rgba(0,0,0,0.5); }
    .input-group { display: flex; flex-direction: column; margin-bottom: 20px; }
    .input-group label { font-size: 0.9rem; font-weight: bold; margin-bottom: 8px; margin-left: 15px; }
    .input-group input { background-color: #0A0D11; border: 2px solid #CBD2DE; color: #F0F2F5; padding: 12px 20px; border-radius: 50px; font-size: 1rem; outline: none; }
    .btn-cadastrar { width: 100%; background: linear-gradient(180deg, #2b3b4f, #020203); border: 2px solid #CBD2DE; color: #F0F2F5; padding: 15px; border-radius: 50px; font-size: 1.2rem; font-weight: bold; cursor: pointer; margin-top: 10px; }
    .btn-voltar { background: none; border: none; color: #f85149; cursor: pointer; margin-top: 15px; display: block; text-align: center; width: 100%; font-weight: bold; }
</style>
<body>
    <div class="cadastro-container">
        <h2>Cadastro de Usuário</h2>
        <form action="/aluno/cadastrar" method="POST">
            <div class="input-group">
                <label for="nome">Nome Completo</label>
                <input type="text" id="nome" name="nome" placeholder="Digite seu nome" required>
            </div>
            <div class="input-group">
                <label for="idade">Idade</label>
                <input type="number" name="idade" placeholder="Digite a idade" required>
            </div>
            <button class="btn-cadastrar" type="submit">Cadastrar Conta</button>
        </form>
        <button class="btn-voltar" onclick="window.location.href='/'">Voltar</button>
    </div>
</body>
</html>