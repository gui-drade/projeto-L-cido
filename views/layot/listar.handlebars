<h2>Painel de Administradores</h2>
<a href="/cadastrar" class="btn btn-add">Novo Administrador</a>

<table>
    <thead>
        <tr>
            <th>CPF</th>
            <th>Nome</th>
            <th>E-mail</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        {{#each adms}}
        <tr>
            <td>{{./cpf}}</td>
            <td>{{./nome}}</td>
            <td>{{./email}}</td>
            <td>
                <a href="/editar/{{./cpf}}" class="btn btn-edit">Editar</a>
                <a href="/deletar/{{./cpf}}" class="btn btn-del" onclick="return confirm('Tem certeza que deseja deletar este administrador?')">Deletar</a>
            </td>
        </tr>
        {{else}}
        <tr>
            <td colspan="4" style="text-align: center; color: #777; padding: 20px;">.
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>